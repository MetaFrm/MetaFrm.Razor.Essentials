@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web

<div class="@($"{this.CssClass} {this.CssClassAppend}")">
    @if (this.Control != null)
    {
        @if (this.Label != null)
        {
            <div class="@this.CssClassLabel">@Localization[this.Label ?? ""]
                @if (this.TooltipText != null)
                {
                    <Tooltip>
                        <Text>
                            @this.TooltipText
                        </Text>
                    </Tooltip>
                }
                @(this.IsColon ? " :" : "")
            </div>
        }
        <div class="@this.CssClassControl">
            @this.Control
        </div>
    }
    else
    {
        @if (this.Label != null)
        {
            <div class="@this.CssClassLabel">@Localization[this.Label ?? ""]
                @if (this.TooltipText != null)
                {
                    <div class="tooltip-container">
                        <span class="tooltip-trigger bi bi-question-circle ms-1"></span>
                        <div class="tooltip">
                            @this.TooltipText
                        </div>
                    </div>
                }
                @(this.IsColon ? " :" : "")
            </div>
        }
        <div class="@this.CssClassControlIsNull">
            @if (this.Value == null || (this.Value is string str && string.IsNullOrEmpty(str)))
            {
                <span>&nbsp;</span>
            }
            else
            {
                @this.Value
            }
        </div>
    }
</div>